<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/draw_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">
    <RelativeLayout
        android:id="@+id/clockLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:keepScreenOn="true">

    <!-- APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#0D6EBD"
            app:titleTextColor="#FFFFFF">
            <TextView
                android:id="@+id/connectionStatusTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/small_padding"
                android:text="Disconnected"
                android:textColor="@color/white"
                  />

            <ImageView
                android:id="@+id/connectionStatus"
                android:layout_width="@dimen/toolbar_icon_size"
                android:layout_height="@dimen/toolbar_icon_size"
                android:layout_marginStart="@dimen/small_padding"
                android:src="@drawable/ic_bluetooth_disconnected"
                app:tint="@color/white" />

        </com.google.android.material.appbar.MaterialToolbar>


    </com.google.android.material.appbar.AppBarLayout>



    <!-- YOUR CONTENT -->
    <LinearLayout
        android:layout_below="@id/appBar"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!-- Digital Counter Background -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">



            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/hk_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friday"
                    android:layout_marginEnd="3dp"
                    android:textColor="@color/white"
                    android:textSize="@dimen/large_time_text"
                    />

                <TextView
                    android:id="@+id/hk_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="12/18/2020"
                    android:textColor="@color/white"
                    android:textSize="@dimen/large_time_text" />
            </LinearLayout>

            <TextView
                android:id="@+id/hk_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="right|center"
                android:text="12:48:12"
                android:layout_marginBottom="@dimen/small_padding"
                android:layout_marginTop="@dimen/small_padding"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />



        </LinearLayout>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <FrameLayout
                android:id="@+id/fragment_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                />
        </ScrollView>


        <LinearLayout
        android:id="@+id/timerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">


        <TextView
            android:id="@+id/txtCounter"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#000000"
            android:fontFamily="@font/digital7"
            android:gravity="right|center"
            android:letterSpacing="0.01"
            android:text="000000"
            android:layout_gravity="right|center"
            android:paddingBottom="127dp"
            android:textColor="#FF0000"
            android:textSize="300sp" />
        <TextView
            android:id="@+id/uNit"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#000000"
            android:text="KG"
            android:gravity="left|center"
            android:layout_gravity="center"
            android:textColor="#FF0000"
            android:textSize="60sp"


            />
    </LinearLayout>
        <!-- Fragment Container -->

        <LinearLayout
            android:id="@+id/abc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:gravity="center"

            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonA"
                style="@style/CircleButton_a"
                android:text="1"
                android:background="@drawable/circle_button_bg_a"
                android:backgroundTint="@null"
                app:backgroundTint="@null"/>


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonB"
                style="@style/CircleButton_b"
                android:text="2"
                android:background="@drawable/circle_button_bg_b"
                android:backgroundTint="@null"
                app:backgroundTint="@null"/>


        </LinearLayout>



    </LinearLayout>
    <!-- Bottom Buttons -->
    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:itemTextAppearance="@style/NavItemTextSmall"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/navigation_menu">
    </com.google.android.material.navigation.NavigationView>
</androidx.drawerlayout.widget.DrawerLayout>